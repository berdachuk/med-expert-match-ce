{
  "schema": 1,
  "memory_bank": {
    "required_files": [
      "projectbrief.md", "productContext.md", "systemPatterns.md",
      "techContext.md", "activeContext.md", "progress.md", "decisions.md"
    ],
    "max_file_lines": 100,
    "index_file": "INDEX.md",
    "session_bootstrap_files": ["INDEX.md"],
    "on_demand_read": true,
    "freshness_warn_days": {
      "activeContext": 7,
      "progress": 14,
      "systemPatterns": 30,
      "techContext": 30
    },
    "generated_files": [
      "activeContext.md", "progress.md", "decisions.md",
      "productContext.md", "plans/00-index.md"
    ],
    "generated_files_note": "Regenerated by scripts/sync-memory-index.sh from registry/*.jsonl + records/. Never hand-edit; never auto-stash. CI asserts via sync-memory-index.sh --check.",
    "source_of_truth": {
      "stable_ids": "registry/*.jsonl (append-only, multi-agent safe)",
      "per_record": "records/{progress,active,deferred,decisions}/",
      "locks": "locks/<module>.md"
    }
  },
  "agents_md": {
    "root_max_lines": 150,
    "root_max_kb": 15,
    "nested_max_lines": 100,
    "nested_max_kb": 4,
    "max_nested_files": 5,
    "monorepo_max_nested_files": 8,
    "nested_modules": ["core", "llm", "retrieval", "web", "ingestion"]
  },
  "skills": {
    "min_count": 4,
    "max_count": 10,
    "require_frontmatter": true,
    "skill_max_lines": 200,
    "note": "Repo currently has 12 skills (over max_count); domain-specific skills (graph-db, llm-prompts, bdd-traceability) are intentional and pre-existing. max_count is advisory, not enforced."
  },
  "plans": {
    "naming": "M{NN}-{goal-slug}.md",
    "index": "00-index.md",
    "archive_dir": "archive/",
    "note": "Repo convention is M{NN} (literal, no dash before number). Template M-NN is NOT used here."
  },
  "validation": {
    "auto_run": true,
    "halt_on_failure": false
  },
  "adapters": {
    "auto_detect": true,
    "declared": false,
    "note": "adapters.json omitted by user choice. De-facto adapters exist: .kilo/ (Kilo), .cursor/rules/ (Cursor). They derive from .agents/skills/, not a source of truth."
  },
  "gitignore_policy": "A",
  "gitignore_local_only": [
    ".agents/memory-bank/INDEX.md",
    ".agents/memory-bank/bootstrap-events.jsonl",
    ".agents/snapshot.md"
  ],
  "gitignore_committed": [
    ".agents/config.json",
    "AGENTS.md",
    ".agents/memory-bank/projectbrief.md",
    ".agents/memory-bank/productContext.md",
    ".agents/memory-bank/systemPatterns.md",
    ".agents/memory-bank/techContext.md",
    ".agents/memory-bank/progress.md",
    ".agents/memory-bank/decisions.md",
    ".agents/skills/",
    ".agents/plans/",
    "docs/ai-context-strategy.md"
  ]
}