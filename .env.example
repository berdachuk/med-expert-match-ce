# MedExpertMatch production environment variables
# Copy this file to .env and adjust values for your deployment

# Spring profile: use "docker" for containerized deployments
SPRING_PROFILES_ACTIVE=docker

# Database
POSTGRES_USER=medexpertmatch
POSTGRES_PASSWORD=changeme
POSTGRES_DB=medexpertmatch
DB_PORT=5433

# Application
APP_PORT=8094
APP_LOG_DIR=./logs

# LLM API endpoints (must be network-reachable from the app container)
CHAT_BASE_URL=http://ollama-host:11434/v1
CHAT_API_KEY=any
CHAT_MODEL=medgemma1.5:4b
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=6000

EMBEDDING_BASE_URL=http://ollama-host:11434/v1
EMBEDDING_API_KEY=any
EMBEDDING_MODEL=nomic-embed-text:v1.5
EMBEDDING_DIMENSIONS=768

RERANKING_BASE_URL=
RERANKING_API_KEY=
RERANKING_MODEL=medgemma1.5:4b
RERANKING_TEMPERATURE=0.1

TOOL_CALLING_BASE_URL=
TOOL_CALLING_API_KEY=
TOOL_CALLING_MODEL=functiongemma:270m
TOOL_CALLING_TEMPERATURE=0.7
TOOL_CALLING_MAX_TOKENS=4096

# LLM concurrency (keep at 1 for local Ollama)
LLM_CONCURRENT_CALLS=1

# Agent skills
SKILLS_ENABLED=true
SKILLS_DIRECTORY=skills
