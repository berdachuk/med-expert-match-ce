# MedExpertMatch Docker stack environment variables
# Copy to .env and adjust:  cp .env.example .env
#
# OLLAMA_BASE_URL must be reachable from the app container (network_mode: host).
# If Ollama runs on another machine on your LAN, use its IP — not 127.0.0.1.

# Shared OpenAI-compatible endpoint (Ollama, LM Studio, LiteLLM, etc.)
OLLAMA_BASE_URL=http://192.168.0.73:11434/v1

# Spring profile for docker-compose app service
SPRING_PROFILES_ACTIVE=local,debug

# Database (postgres service exposes 5433 on host)
POSTGRES_USER=medexpertmatch
POSTGRES_PASSWORD=medexpertmatch
POSTGRES_DB=medexpertmatch
DB_PORT=5433

# Application
APP_PORT=8094
APP_LOG_DIR=./logs

# LLM API (optional per-service overrides; default is OLLAMA_BASE_URL for all)
# CHAT_BASE_URL=http://192.168.0.73:11434/v1
CHAT_API_KEY=any
CHAT_MODEL=medgemma1.5:4b
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=6000

# EMBEDDING_BASE_URL=http://192.168.0.73:11434/v1
EMBEDDING_API_KEY=any
EMBEDDING_MODEL=nomic-embed-text:v1.5
EMBEDDING_DIMENSIONS=768

# RERANKING_BASE_URL=http://192.168.0.73:11434/v1
RERANKING_API_KEY=any
RERANKING_MODEL=medgemma1.5:4b
RERANKING_TEMPERATURE=0.1

# TOOL_CALLING_BASE_URL=http://192.168.0.73:11434/v1
TOOL_CALLING_API_KEY=any
TOOL_CALLING_MODEL=functiongemma:270m
TOOL_CALLING_TEMPERATURE=0.7
TOOL_CALLING_MAX_TOKENS=4096

# LLM concurrency (keep at 1 for local Ollama)
LLM_CONCURRENT_CALLS=1

# Agent skills
SKILLS_ENABLED=true
SKILLS_DIRECTORY=skills
